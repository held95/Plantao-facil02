{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "env": [
        "NEXTAUTH_URL",
        "NEXTAUTH_SECRET",
        "AUTH_SOURCE",
        "AWS_REGION",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_DYNAMODB_USERS_TABLE",
        "AWS_DYNAMODB_RESET_TABLE",
        "AWS_DYNAMODB_USERS_EMAIL_GSI",
        "AWS_DYNAMODB_PLANTOES_TABLE",
        "ENABLE_EMAIL_NOTIFICATIONS",
        "AWS_SES_FROM_EMAIL",
        "AWS_SES_REPLY_TO",
        "ENABLE_SMS_NOTIFICATIONS",
        "APP_BASE_URL",
        "NEXT_PUBLIC_API_BASE_URL",
        "NEXT_PUBLIC_APP_NAME",
        "PASSWORD_RESET_TOKEN_TTL_MINUTES",
        "AWS_DYNAMODB_MESSAGES_TABLE",
        "AWS_DYNAMODB_TOTP_TABLE"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "type-check": {
      "dependsOn": ["^build"]
    }
  }
}
